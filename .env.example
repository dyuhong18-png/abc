# api_key or GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects 'api_key' at runtime from user secrets.
# For hosting platforms like Render, configure 'GEMINI_API_KEY' in the environment settings.
GEMINI_API_KEY="your_gemini_api_key_here"
api_key="your_gemini_api_key_here"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"
